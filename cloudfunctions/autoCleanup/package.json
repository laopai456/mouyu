{
  "name": "autoCleanup",
  "version": "1.0.0",
  "description": "自动清理3天前的图片",
  "main": "index.js",
  "dependencies": {
    "wx-server-sdk": "~2.6.3"
  },
  "cloudfunction-config": {
    "memorySize": 256,
    "timeout": 60
  },
  "triggers": [
    {
      "name": "dailyCleanup",
      "type": "timer",
      "config": "0 0 2 * * * *"
    }
  ]
}
