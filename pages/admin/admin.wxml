<view class="container">
  <view class="openid-section">
    <text class="openid-label">我的ID：</text>
    <text class="openid-value" bindtap="copyOpenid">{{openid}}</text>
    <text class="openid-tip" bindtap="copyOpenid">（点击复制）</text>
  </view>

  <view class="tabs" wx:if="{{isAdmin}}">
    <view class="tab {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">待审核 ({{pendingCount}})</view>
    <view class="tab {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">已通过</view>
    <view class="tab {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-tab="2">已拒绝</view>
  </view>

  <block wx:if="{{currentTab === 0 && isAdmin}}">
    <view class="review-mode" wx:if="{{currentImage}}">
      <view class="review-counter">{{currentIndex + 1}} / {{images.length}}</view>
      <image class="review-image" src="{{currentImage.url}}" mode="aspectFit" bindtap="previewCurrentImage" />
      <view class="review-info">
        <text class="review-time">{{currentImage.createTimeStr}}</text>
      </view>
      <view class="review-actions">
        <view class="review-btn review-reject" bindtap="reject">拒绝</view>
        <view class="review-btn review-approve" bindtap="approve">通过</view>
      </view>
    </view>
    <view class="empty" wx:elif="{{images.length === 0 && !loading}}">
      <text>暂无待审核内容 🎉</text>
    </view>
  </block>

  <scroll-view class="list" scroll-y enhanced show-scrollbar="{{false}}" wx:elif="{{isAdmin}}">
    <block wx:for="{{images}}" wx:key="_id">
      <view class="item">
        <image class="preview" src="{{item.url}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.url}}" />
        <view class="info">
          <text class="time">{{item.createTimeStr}}</text>
          <view class="status" wx:if="{{currentTab === 1}}">
            <text class="approved">已通过</text>
          </view>
          <view class="status" wx:elif="{{currentTab === 2}}">
            <text class="rejected">已拒绝</text>
          </view>
        </view>
      </view>
    </block>

    <view class="empty" wx:if="{{images.length === 0}}">
      <text>暂无内容</text>
    </view>
  </scroll-view>
</view>
