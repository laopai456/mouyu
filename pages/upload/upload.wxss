page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding: 40rpx;
}

.upload-area {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx dashed #fff;
  border-radius: 20rpx;
  height: 300rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
}

.upload-icon {
  font-size: 80rpx;
  color: #667eea;
  font-weight: bold;
}

.upload-text {
  font-size: 32rpx;
  color: #333;
  margin-top: 20rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.preview-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 40rpx;
}

.preview-item {
  width: 200rpx;
  height: 200rpx;
  margin: 10rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.preview-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.upload-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
}

.tips {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
