<view class="container">
  <scroll-view 
    class="image-area" 
    scroll-y 
    enhanced 
    show-scrollbar="{{false}}"
    refresher-enabled
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="image-wrapper">
      <block wx:if="{{noMoreImages}}">
        <view class="no-more">
          <text class="no-more-text">{{noMoreText}}</text>
        </view>
      </block>
      <block wx:else>
        <image 
          class="meme-image" 
          src="{{imageUrl}}" 
          mode="widthFix" 
          binderror="onImageError"
          bindload="onImageLoad"
        />
      </block>
    </view>
  </scroll-view>

  <view class="header">
    <view class="header-left">
      <view class="like-btn {{hasLikedToday ? 'disabled' : ''}}" bindtap="onLike">
        <text class="like-icon">🌸</text>
        <text class="action-count">{{likeCount}}</text>
      </view>
      <view class="slogan-wrapper">
        <text class="slogan" bindtap="onTitleTap">热爱可抵漫长岁月</text>
        <text class="slogan-sub">沙雕趣图搬运工</text>
      </view>
    </view>
    <view class="upload-btn" bindtap="goUpload" wx:if="{{canUpload}}">
      <text>+</text>
    </view>
  </view>

  <view class="dislike-btn {{dislikeCount <= 0 ? 'disabled' : ''}}" bindtap="onDislike" wx:if="{{!noMoreImages && dislikeCount > 0}}">
    <text class="dislike-icon">💩</text>
    <text class="action-count">{{dislikeCount}}</text>
  </view>

  <view class="laugh-btn" bindtap="onLaugh">
    <text class="laugh-icon">哈</text>
  </view>

  <view class="laugh-container">
    <view 
      wx:for="{{flyingTexts}}"
      wx:key="id"
      class="flying-text {{item.effect}}"
      style="{{item.style}}"
    >{{item.text}}</view>
  </view>

  <view class="stage-light" wx:if="{{stageLight}}">
    <view class="spotlight"></view>
    <view class="spotlight"></view>
    <view class="spotlight"></view>
    <view class="spotlight"></view>
  </view>
</view>
