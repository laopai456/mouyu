page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  height: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

.container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: 140rpx;
  padding-bottom: 140rpx;
}

.image-area {
  width: 100%;
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.image-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100%;
  box-sizing: border-box;
}

.meme-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.no-more {
  text-align: center;
  padding: 60rpx;
}

.no-more-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.header {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.slogan-wrapper {
  display: flex;
  flex-direction: column;
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-style: italic;
  letter-spacing: 4rpx;
}

.slogan-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 2rpx;
  margin-top: 4rpx;
}

.like-btn, .dislike-btn, .upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  z-index: 100;
}

.like-btn {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
  box-shadow: 0 4rpx 20rpx rgba(255, 154, 158, 0.4);
}

.like-icon, .dislike-icon {
  font-size: 36rpx;
}

.action-count {
  font-size: 18rpx;
  color: #fff;
  margin-top: 2rpx;
}

.dislike-btn {
  position: fixed;
  left: 40rpx;
  bottom: 40rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  box-shadow: 0 4rpx 20rpx rgba(238, 90, 90, 0.4);
}

.laugh-btn {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffb830 0%, #ff9500 50%, #ff6b00 100%);
  box-shadow:
    0 8rpx 25rpx rgba(255, 149, 0, 0.5),
    inset 0 -4rpx 10rpx rgba(0, 0, 0, 0.1),
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.laugh-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #fff;
  text-shadow:
    0 4rpx 0 rgba(200, 100, 0, 0.3),
    0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  transform: scale(1, 1.1);
  letter-spacing: -2rpx;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.laugh-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1000;
  overflow: hidden;
}

.flying-text {
  position: absolute;
  font-weight: bold;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
  animation: flyUp ease-out forwards;
  white-space: nowrap;
  background: #ff6b6b;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.6);
}

@keyframes flyUp {
  0% {
    opacity: 1;
    transform: translateY(0) scale(0.5);
  }
  15% {
    transform: translateY(-30rpx) scale(1.1);
  }
  30% {
    transform: translateY(-60rpx) scale(1);
  }
  80% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translateY(-400rpx) scale(0.8);
  }
}

.flying-text.gradient {
  background: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #9b59b6);
  background-size: 300% 300%;
  animation: flyUp ease-out forwards, gradientShift 1s ease infinite;
  box-shadow: 0 0 30rpx rgba(255, 107, 107, 0.8), 0 0 60rpx rgba(255, 217, 61, 0.5);
  z-index: 1001;
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.flying-text.neon {
  background: transparent;
  color: #fff;
  text-shadow:
    0 0 10rpx #ff6b6b,
    0 0 20rpx #ff6b6b,
    0 0 40rpx #ff6b6b,
    0 0 80rpx #ff6b6b;
  box-shadow: none;
  animation: flyUp ease-out forwards, neonPulse 0.5s ease infinite alternate;
  z-index: 1001;
}

@keyframes neonPulse {
  from {
    text-shadow:
      0 0 10rpx #ff6b6b,
      0 0 20rpx #ff6b6b,
      0 0 40rpx #ff6b6b,
      0 0 80rpx #ff6b6b;
  }
  to {
    text-shadow:
      0 0 5rpx #ff9ff3,
      0 0 10rpx #ff9ff3,
      0 0 20rpx #ff9ff3,
      0 0 40rpx #ff9ff3;
  }
}

.flying-text.glitch {
  background: rgba(0, 0, 0, 0.8);
  color: #fff;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    0 0 20rpx rgba(77, 150, 255, 0.6),
    inset 0 0 20rpx rgba(155, 89, 182, 0.3);
  animation: flyUp ease-out forwards, glitchEffect 0.3s ease infinite;
  z-index: 1001;
}

@keyframes glitchEffect {
  0%, 100% { transform: translateY(0) translateX(0); }
  25% { transform: translateY(-2rpx) translateX(2rpx); }
  50% { transform: translateY(0) translateX(-2rpx); }
  75% { transform: translateY(-1rpx) translateX(1rpx); }
}

.flying-text.poop {
  background: transparent;
  animation: flyUpPoop ease-out forwards;
}

@keyframes flyUpPoop {
  0% {
    opacity: 1;
    transform: translateY(0) rotate(var(--rotation, 0deg)) scale(0.3);
  }
  20% {
    opacity: 1;
    transform: translateY(-50rpx) rotate(var(--rotation, 0deg)) scale(1.3);
  }
  40% {
    transform: translateY(-100rpx) rotate(var(--rotation, 0deg)) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-300rpx) rotate(var(--rotation, 0deg)) scale(0.5);
  }
}

.stage-light {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
  background: rgba(0, 0, 0, 0.5);
}

.stage-light::before,
.stage-light::after {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  top: -50%;
  left: -50%;
}

.spotlight {
  position: absolute;
  top: -100rpx;
  width: 0;
  height: 0;
  border-left: 150rpx solid transparent;
  border-right: 150rpx solid transparent;
  border-top: 1200rpx solid rgba(255, 255, 255, 0.15);
  filter: blur(20rpx);
  animation: spotlightSway 4s ease-in-out infinite;
  transform-origin: top center;
}

.spotlight:nth-child(1) {
  left: 5%;
  border-top-color: rgba(255, 107, 107, 0.25);
  animation-delay: 0s;
}

.spotlight:nth-child(2) {
  left: 30%;
  border-top-color: rgba(255, 217, 61, 0.2);
  animation-delay: -1s;
}

.spotlight:nth-child(3) {
  right: 30%;
  border-top-color: rgba(77, 150, 255, 0.2);
  animation-delay: -2s;
}

.spotlight:nth-child(4) {
  right: 5%;
  border-top-color: rgba(155, 89, 182, 0.25);
  animation-delay: -3s;
}

@keyframes spotlightSway {
  0%, 100% {
    transform: rotate(-15deg);
  }
  50% {
    transform: rotate(15deg);
  }
}

.upload-btn {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.upload-btn text {
  font-size: 48rpx;
  color: #667eea;
  font-weight: 300;
  line-height: 1;
}
