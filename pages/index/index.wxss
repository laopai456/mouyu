page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  height: 100vh;
  overflow: hidden;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
}

.image-area {
  width: 100%;
  height: 100vh;
}

.image-wrapper {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.meme-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.no-more {
  text-align: center;
  padding: 60rpx;
}

.no-more-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.header {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-style: italic;
  letter-spacing: 4rpx;
}

.like-btn, .dislike-btn, .upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  z-index: 100;
}

.like-btn {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
  box-shadow: 0 4rpx 20rpx rgba(255, 154, 158, 0.4);
}

.like-icon, .dislike-icon {
  font-size: 36rpx;
}

.action-count {
  font-size: 18rpx;
  color: #fff;
  margin-top: 2rpx;
}

.dislike-btn {
  position: fixed;
  left: 40rpx;
  bottom: 40rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  box-shadow: 0 4rpx 20rpx rgba(238, 90, 90, 0.4);
}

.upload-btn {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.upload-btn text {
  font-size: 48rpx;
  color: #667eea;
  font-weight: 300;
  line-height: 1;
}
